@BACK_URL = https://localhost:7171/api


### Get all reports
GET {{BACK_URL}}/Report
Authorization: Bearer {{auth_token}}


### Get a report by id
GET {{BACK_URL}}/Report/1
Authorization: Bearer {{auth_token}}


### Create report (new payload)
POST {{BACK_URL}}/Report
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "reason": 2,
  "targetUserId": 2,
  "targetPostId": null,
  "targetCommentId": null,
  "comment": "This user is sending harassing messages."
}


### Create report (legacy-compatible payload)
POST {{BACK_URL}}/Report
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "reason": 1,
  "reportedUserId": null,
  "postId": 5,
  "commentId": null,
  "description": "This post looks like spam.",
  "reporterUserId": 1
}


### Update an existing report (mark as reviewed)
PUT {{BACK_URL}}/Report
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "id": 1,
  "reporterUserId": 1,
  "reason": 2,
  "status": 1,
  "comment": "Under review by moderation team.",
  "targetUserId": 2,
  "targetPostId": null,
  "targetCommentId": null
}


### Delete a report
DELETE {{BACK_URL}}/Report/1
Authorization: Bearer {{auth_token}}
